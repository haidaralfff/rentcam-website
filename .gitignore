# Ignore compiled/generated folders
system/
vendor/

# Ignore uploads (user-generated files)
assets/uploads/

# Ignore environment config
.env

# Ignore logs and cache
application/logs/*
application/cache/*

# Keep gitkeep files
!application/logs/.gitkeep
!application/cache/.gitkeep
!assets/uploads/.gitkeep

# Ignore project planning and prompts
prompt/project_plan.md

# Ignore large assets
assets/mockup/
assets/picture/

# Ignore session files
application/session/*
!application/session/.gitkeep

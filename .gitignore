# Ignore compiled/generated folders
vendor/
node_modules/

# Ignore uploads (user-generated files)
assets/uploads/

# Ignore environment config (Contains secrets)
.env

# Ignore logs and cache
application/logs/*
application/cache/*

# Keep gitkeep files
!application/logs/.gitkeep
!application/cache/.gitkeep
!assets/uploads/.gitkeep

# Ignore project planning and AI prompts
prompt/

# Ignore large assets
assets/mockup/
assets/picture/

# Ignore session files
application/session/*
!application/session/.gitkeep

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db

# IDE configuration files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
